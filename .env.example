# Copy to .env / .env.local and fill in. Native fetch requires Node 18+ (Node 20+ recommended).

# --- Data & Intelligence (Person A) ---
NEWS_API_KEY=
LLM_API_KEY=
LLM_BASE_URL=        # OpenAI-compatible base, e.g. https://openrouter.ai/api/v1 or https://api.groq.com/openai/v1
LLM_MODEL=           # e.g. meta-llama/llama-3.1-8b-instruct  or  llama-3.1-8b-instant

# Person A tuning (optional; defaults shown)
TOP_N_STORIES=5      # how many stories to summarize/enqueue per run
MIN_MEME_SCORE=6     # drop stories scoring below this (1-10)

# --- Generation (Person B) ---
MINIMAX_API_KEY=
MINIMAX_GROUP_ID=
BLOB_READ_WRITE_TOKEN=
SLACK_WEBHOOK_URL=
VAPI_API_KEY=        # used by local pipeline.ts v0 placeholder TTS; serverless run-b uses MiniMax TTS

# MiniMax TTS voice (optional override for run-b)
MINIMAX_VOICE_ID=English_expressive_narrator

# --- Shared ---
KV_URL=
KV_REST_API_URL=
KV_REST_API_TOKEN=
DAILY_VIDEO_BUDGET_USD=5