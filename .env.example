# Copy to .env and fill in. Native fetch requires Node 18+ (Node 20+ recommended).

# --- Data & Intelligence (Person A) ---
NEWS_API_KEY=
LLM_API_KEY=
LLM_BASE_URL=        # OpenAI-compatible base, e.g. https://openrouter.ai/api/v1 or https://api.groq.com/openai/v1
LLM_MODEL=           # e.g. meta-llama/llama-3.1-8b-instruct  or  llama-3.1-8b-instant

# Person A tuning (optional; defaults shown)
TOP_N_STORIES=5      # how many stories to summarize/enqueue per run
MIN_MEME_SCORE=6     # drop stories scoring below this (1-10)

# --- Vercel KV (queue) — needed unless running run-a with --dry ---
KV_URL=
KV_REST_API_URL=
KV_REST_API_TOKEN=

# --- Generation (Person B) ---
MINIMAX_API_KEY=
VAPI_API_KEY=
VAPI_TTS_URL=            # optional override; defaults to https://api.vapi.ai/tts

# Blob + notifications
BLOB_READ_WRITE_TOKEN=
SLACK_WEBHOOK_URL=

# Shared budget guard (checked before every paid call)
DAILY_VIDEO_BUDGET_USD=5.0

# Optional: for local run-b testing against KV
# KV_URL=
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
